# ISMA Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# .env is gitignored — it will never be committed.

# --- Weaviate (vector store) ---
# Default = the local docker-compose demo store, so `cp .env.example .env && docker compose up`
# works out-of-the-box (docker-compose.yml maps Weaviate on 8080).
# Production deployments override this to their own store (e.g. http://localhost:8088).
WEAVIATE_URL=http://localhost:8080

# --- Neo4j (knowledge graph) ---
NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=
# NEO4J_PASSWORD=

# --- Redis (cache + HMM inverted index) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Embedding server ---
EMBEDDING_URL=http://localhost:8089/v1/embeddings

# --- Reranker ---
RERANKER_URL=http://localhost:8085
# RERANKER_ENGINE=gte  # Options: qwen3 (default), gte

# --- Query API ---
ISMA_QUERY_API=http://localhost:8095

# --- CORS (browser clients; comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# --- Auth (required to enable write endpoints) ---
# ISMA_API_KEY=

# --- Data directories ---
# Left commented so the code's user-writable defaults apply (state dir defaults to
# ~/.local/share/isma — no root/PermissionError). Uncomment any to override.
# Note: use absolute paths here; .env values are NOT shell-expanded (no ~).
# ISMA_STATE_DIR=/var/lib/isma
# ISMA_DATA_DIR=/var/lib/isma/data
# ISMA_CANONICAL_MAPPING_PATH=/var/lib/isma/data/corpus/f1_canonical_mapping.json  # for /motifs + /themes; not shipped with the demo
# ISMA_TEMPORAL_LOG_DIR=/var/lib/isma/temporal
# ISMA_TEMPORAL_DOLT_DIR=/var/lib/isma/isma-dolt
# ISMA_THEME_INDEX_PATH=/var/lib/isma/theme_search_index.json
# ISMA_HMM_PKG_STATE_PATH=/var/lib/isma/hmm_pkg_state.json
# ISMA_HMM_PKG_DIR=/tmp/hmm_packages
# ISMA_BENCHMARK_OUTPUT_DIR=/var/lib/isma/benchmarks
# ISMA_MANIFEST_DIR=/var/lib/isma

# --- Nightly ingest (optional — for syncing from another machine) ---
# NIGHTLY_SYNC_HOST=user@your-hostname
# NIGHTLY_SYNC_CLAUDE_PROJECTS=/path/to/your/.claude/projects/
# NIGHTLY_SYNC_HOME=/path/to/your/home/
